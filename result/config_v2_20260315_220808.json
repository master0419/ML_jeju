{
  "data_dir": "C:\\Users\\7slwm\\Downloads\\data_jeju\\data",
  "data_files": {
    "acc_pay": "acc_pay_df.parquet",
    "acc_rec": "acc_rec_df.parquet",
    "ap_days": "ap_days_df.parquet",
    "ar_days": "ar_days_df.parquet",
    "coa": "coa_df.parquet",
    "purchase": "purchase_df.parquet",
    "revenue": "revenue_df.parquet"
  },
  "target_col": "TOT_MN_MNAM",
  "main_table": "revenue",
  "date_col": "DM_DATA",
  "window_size": 12,
  "rolling_windows": [
    3,
    6,
    12
  ],
  "forecast_months": 6,
  "forecast_start": "2025-01",
  "use_log_transform": true,
  "use_tscv": true,
  "tscv_n_splits": 5,
  "tscv_valid_size": 6,
  "use_exogenous_features": true,
  "use_advanced_features": true,
  "use_fourier_features": true,
  "fourier_order": 3,
  "use_feature_selection": true,
  "feature_selection_method": "importance",
  "feature_selection_threshold": 0.01,
  "valid_months": 6,
  "random_state": 42,
  "early_stopping_rounds": 50,
  "models": {
    "XGBoost": true,
    "LightGBM": true,
    "CatBoost": true,
    "GradientBoosting": true,
    "RandomForest": true,
    "Ridge": true,
    "Prophet": false,
    "Ensemble_Voting": true,
    "Ensemble_Stacking": true,
    "Ensemble_Weighted": true,
    "LinearRegression": false,
    "Lasso": false,
    "ElasticNet": false
  },
  "model_params": {
    "XGBoost": {
      "n_estimators": 500,
      "max_depth": 4,
      "learning_rate": 0.05,
      "subsample": 0.8,
      "colsample_bytree": 0.8,
      "reg_alpha": 0.1,
      "reg_lambda": 1.0,
      "min_child_weight": 3,
      "random_state": 42,
      "verbosity": 0
    },
    "LightGBM": {
      "n_estimators": 500,
      "max_depth": 4,
      "learning_rate": 0.05,
      "num_leaves": 15,
      "min_child_samples": 10,
      "subsample": 0.8,
      "colsample_bytree": 0.8,
      "reg_alpha": 0.1,
      "reg_lambda": 2.0,
      "random_state": 42,
      "verbose": -1
    },
    "CatBoost": {
      "iterations": 500,
      "depth": 4,
      "learning_rate": 0.05,
      "l2_leaf_reg": 3.0,
      "random_state": 42,
      "verbose": false,
      "allow_writing_files": false
    },
    "GradientBoosting": {
      "n_estimators": 300,
      "max_depth": 4,
      "learning_rate": 0.03,
      "min_samples_split": 5,
      "min_samples_leaf": 3,
      "subsample": 0.8,
      "random_state": 42
    },
    "RandomForest": {
      "n_estimators": 200,
      "max_depth": 8,
      "min_samples_split": 5,
      "min_samples_leaf": 3,
      "random_state": 42,
      "n_jobs": -1
    },
    "Ridge": {
      "alpha": 1.0
    }
  },
  "ensemble": {
    "voting_weights": [
      2,
      2,
      2,
      1
    ],
    "stacking_final": "Ridge",
    "stacking_cv": 5,
    "optimize_weights": true
  },
  "optuna": {
    "enabled": false,
    "n_trials": 50,
    "timeout": 600,
    "models_to_optimize": [
      "XGBoost",
      "LightGBM",
      "CatBoost"
    ]
  },
  "model_dir": "./model",
  "history_dir": "./model/history",
  "save_results": true,
  "results_dir": "./result",
  "plot_results": true,
  "experiment_name": "고도화 v2: 외생피처 + CatBoost + Optuna",
  "experiment_changes": [
    "외생 변수 피처 추가 (매출채권/매입채무 테이블)",
    "고급 시계열 피처 (추세, Fourier, EMA)",
    "CatBoost 모델 추가",
    "Optuna 하이퍼파라미터 최적화 지원",
    "앙상블 가중치 최적화",
    "피처 선택 (중요도 기반)"
  ]
}